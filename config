{
    "layer": "top",
    "position": "top",
    "margin-top": 10,
    "margin-bottom": 0,
    "height": 40,
    // Убираем left и right margin, чтобы панель сжалась по центру
    "modules-center": [
        "group/hardware",
        "clock"
    ],

    // --- Настройка группы "Железо" (Скрытая по умолчанию) ---
    "group/hardware": {
        "orientation": "horizontal",
        "modules": [
            "custom/system_icon", // То, что видно всегда
            "cpu",                // Скрыто
            "memory",             // Скрыто
            "temperature"         // Скрыто
        ],
        "drawer": {
            "transition-duration": 300,
            "children-class": "hw-stats",
            "transition-left-to-right": false
        }
    },

    // --- Сами модули ---
    "custom/system_icon": {
        "format": "", // Иконка чипа из Nerd Fonts
        "tooltip": false
    },
    "cpu": {
        "format": "{usage}% ",
        "tooltip": false
    },
    "memory": {
        "format": "{}% "
    },
    "temperature": {
        "format": "{temperatureC}°C "
    },
    "clock": {
        "format": "{:%H:%M - %d.%m}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>"
    }
}

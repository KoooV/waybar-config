{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "height": 40,
    "spacing": 6,

    "modules-center": [
        "group/taskbar_drawer", 
        "group/tray_drawer",    
        "group/hardware",       
        "group/battery_drawer", 
        "clock",                
        "custom/settings",      
        "group/power",          
        "privacy"               
    ],

    "group/taskbar_drawer": {
        "orientation": "horizontal",
        "drawer": { "transition-duration": 300, "transition-left-to-right": true },
        "modules": ["custom/apps_icon", "wlr/taskbar"]
    },
    "custom/apps_icon": { "format": "󰣆" },
    "wlr/taskbar": { "format": "{icon}", "icon-size": 18, "on-click": "activate" },

    "group/tray_drawer": {
        "orientation": "horizontal",
        "drawer": { "transition-duration": 300, "transition-left-to-right": true },
        "modules": ["custom/tray_icon", "tray"]
    },
    "custom/tray_icon": { "format": "󱊖" },
    "tray": { "icon-size": 18, "spacing": 10 },

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature"]
    },
    "cpu": { "format": " {usage}%" },
    "memory": { "format": " {}%" },
    "temperature": { "format": " {temperatureC}°C", "tooltip": false },

    // --- БАТАРЕЯ И РЕЖИМЫ ПИТАНИЯ ---
    "group/battery_drawer": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false,
            "click-to-reveal": true 
        },
        "modules": [
            "battery", 
            "custom/pp-perf",
            "custom/pp-balanced",
            "custom/pp-saver"
        ]
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip": false
    },

    // Модули с проверкой текущего режима (интервал 2 сек)
    "custom/pp-perf": {
        "format": "󰓅",
        "exec": "if [ $(powerprofilesctl get) = 'performance' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set performance",
        "tooltip-format": "high-performance"
    },
    "custom/pp-balanced": {
        "format": "󰾗",
        "exec": "if [ $(powerprofilesctl get) = 'balanced' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set balanced",
        "tooltip-format": "balance"
    },
    "custom/pp-saver": {
        "format": "󰾆",
        "exec": "if [ $(powerprofilesctl get) = 'power-saver' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set power-saver",
        "tooltip-format": "economy"
    },

    "clock": {
        "format": "{:%H:%M  |  %A, %d %B %Y}",
        "locale": "ru_RU.UTF-8",
        "tooltip": false
    },

    "custom/settings": {
        "format": "",
        "on-click": "swaync-client -t -sw",
        "tooltip": false
    },

    "group/power": {
        "orientation": "horizontal",
        "drawer": { "transition-duration": 300, "transition-left-to-right": false },
        "modules": ["custom/power", "custom/reboot", "custom/sleep", "custom/logout"]
    },
    "custom/power": { "format": "", "on-click": "systemctl poweroff", "tooltip-format": "power-off" },
    "custom/reboot": { "format": "󰜉", "on-click": "systemctl reboot", "tooltip-format": "reboot" },
    "custom/sleep": { "format": "󰒲", "on-click": "systemctl suspend", "tooltip-format": "sleep" },
    "custom/logout": { "format": "󰍃", "on-click": "niri msg action quit", "tooltip-format": "logout" },

    "privacy": {
        "icon-size": 14,
        "modules": [{ "type": "screenshare", "prefix": "󰒔" }, { "type": "audio-in", "prefix": "󰍬" }]
    }
}

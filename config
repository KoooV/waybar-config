{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "height": 40,
    "spacing": 6,

    "modules-center": [
        "group/tray_drawer",    
        "group/hardware",       
        "group/battery_drawer", 
        "clock",                
        "custom/settings",      
        "group/power",          
        "privacy"               
    ],

    "group/tray_drawer": {
        "orientation": "horizontal",
        "drawer": { 
        	"transition-duration": 300,
        	"transition-left-to-right": true },
        "modules": ["custom/tray_icon", "tray"]
    },
    "custom/tray_icon": { 
    	"format": "у±КЦ",
    	"tooltip": false
    	},
    "tray": { 
    	"icon-size": 18, 
    	"spacing": 10,
    	"tooltip": false
    },

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature"]
    },
    "cpu": { "format": "пТЉ {usage}%" },
    "memory": { "format": "пГЙ {}%" },
    "temperature": { "format": "пЛЙ {temperatureC}¬∞C", "tooltip": false },

    // --- –С–Р–Ґ–Р–†–Х–ѓ –Ш –†–Х–Ц–Ш–Ь–Ђ –Я–Ш–Ґ–Р–Э–Ш–ѓ ---
    "group/battery_drawer": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false,
            "click-to-reveal": true 
        },
        "modules": [
            "battery", 
            "custom/pp-perf",
            "custom/pp-balanced",
            "custom/pp-saver"
        ]
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "у∞ВД {capacity}%",
        "format-plugged": "пЗ¶ {capacity}%",
        "format-icons": ["пЙД", "пЙГ", "пЙВ", "пЙБ", "пЙА"],
        "tooltip": false
    },

    // –Ь–Њ–і—Г–ї–Є —Б –њ—А–Њ–≤–µ—А–Ї–Њ–є —В–µ–Ї—Г—Й–µ–≥–Њ —А–µ–ґ–Є–Љ–∞ (–Є–љ—В–µ—А–≤–∞–ї 2 —Б–µ–Ї)
    "custom/pp-perf": {
        "format": "у∞УЕ",
        "exec": "if [ $(powerprofilesctl get) = 'performance' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set performance",
        "tooltip-format": "high-performance"
    },
    "custom/pp-balanced": {
        "format": "у∞ЊЧ",
        "exec": "if [ $(powerprofilesctl get) = 'balanced' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set balanced",
        "tooltip-format": "balance"
    },
    "custom/pp-saver": {
        "format": "у∞ЊЖ",
        "exec": "if [ $(powerprofilesctl get) = 'power-saver' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set power-saver",
        "tooltip-format": "economy"
    },

    "clock": {
        "format": "{:%H:%M  |  %A, %d %B %Y}",
        "locale": "ru_RU.UTF-8",
        "tooltip": false
    },

    "custom/settings": {
        "format": "пАУ",
        "on-click": "pkill -x orbit || orbit > /dev/null 2>&1",
        "tooltip": false
    },

    "group/power": {
        "orientation": "horizontal",
        "drawer": { "transition-duration": 300, "transition-left-to-right": false },
        "modules": ["custom/power", "custom/reboot", "custom/sleep", "custom/logout"]
    },
    "custom/power": { "format": "пАС", "on-click": "systemctl poweroff", "tooltip": false },
    "custom/reboot": { "format": "у∞ЬЙ", "on-click": "systemctl reboot", "tooltip": false },
    "custom/sleep": { "format": "у∞Т≤", "on-click": "systemctl suspend", "tooltip": false },
    "custom/logout": { "format": "у∞НГ", "on-click": "niri msg action quit", "tooltip": false },

    "privacy": {
        "icon-size": 14,
        "modules": [{ "type": "screenshare", "prefix": "у∞ТФ" }, { "type": "audio-in", "prefix": "у∞Нђ" }]
    }
}

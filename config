{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "height": 40,
    "spacing": 6,

    "modules-center": [
        "group/tray_drawer",    
        "group/hardware",                
        "group/battery_drawer", 
        "clock",  
        "group/audio",
        "custom/settings",      
        "group/power",          
        "privacy"               
    ],

    "group/tray_drawer": {
        "orientation": "horizontal",
        "drawer": { 
        	"transition-duration": 300,
        	"transition-left-to-right": true },
        "modules": ["custom/tray_icon", "tray"]
    },
    "custom/tray_icon": { 
    	"format": "󱊖",
    	"tooltip": false
    },
    "tray": { 
    	"icon-size": 18, 
    	"spacing": 10,
    	"tooltip": false
    },

    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature"]
    },
    "cpu": { "format": " {usage}%" },
    "memory": { "format": " {}%" },
    "temperature": { "format": " {temperatureC}°C", "tooltip": false },

    // --- БАТАРЕЯ И РЕЖИМЫ ПИТАНИЯ ---
    "group/battery_drawer": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false,
            "click-to-reveal": true 
        },
        "modules": [
            "battery", 
            "custom/pp-perf",
            "custom/pp-balanced",
            "custom/pp-saver"
        ]
    },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""],
        "tooltip": true,
        "tooltip-format": "{timeTo}"
    },

    // Модули с проверкой текущего режима (интервал 2 сек)
    "custom/pp-perf": {
        "format": "󰓅",
        "exec": "if [ $(powerprofilesctl get) = 'performance' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set performance",
        "tooltip-format": "high-performance"
    },
    "custom/pp-balanced": {
        "format": "󰾗",
        "exec": "if [ $(powerprofilesctl get) = 'balanced' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set balanced",
        "tooltip-format": "balance"
    },
    "custom/pp-saver": {
        "format": "󰾆",
        "exec": "if [ $(powerprofilesctl get) = 'power-saver' ]; then echo '{\"class\": \"active\"}'; else echo '{\"class\": \"inactive\"}'; fi",
        "return-type": "json",
        "interval": 2,
        "on-click": "powerprofilesctl set power-saver",
        "tooltip-format": "economy"
    },

    "clock": {
        "format": "{:%H:%M  |  %A, %d %B %Y}",
        "locale": "ru_RU.UTF-8",
        "tooltip": false
    },

    // --- ЗВУК И МИКРОФОН ---
    "group/audio": {
        "orientation": "horizontal",
        "modules": ["pulseaudio", "pulseaudio#microphone"]
    },
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "󰖁 Muted",
        "format-icons": {
            "headphone": "󰋋",
            "hands-free": "󰋋",
            "headset": "󰋋",
            "phone": "",
            "portable": "",
            "car": "",
            "default": ["󰕿", "󰖀", "󰕾"]
        },
        "scroll-step": 5,
        "on-click": "pavucontrol",
        "tooltip": true,
        "tooltip-format": "{desc}" 
    },
    "pulseaudio#microphone": {
        "format": "{format_source}",
        "format-source": "󰍬 {volume}%",
        "format-source-muted": "󰍭 Muted",
        "scroll-step": 5,
        "on-click": "pavucontrol -t 4",
        "tooltip": true,
        "tooltip-format": "{source_desc}"
    },
    
    "custom/settings": {
        "format": "",
        "on-click": "pkill -x orbit || orbit > /dev/null 2>&1",
        "tooltip": false
    },

    "group/power": {
        "orientation": "horizontal",
        "drawer": { "transition-duration": 300, "transition-left-to-right": false },
        "modules": ["custom/power", "custom/reboot", "custom/sleep", "custom/logout"]
    },
    "custom/power": { "format": "", "on-click": "systemctl poweroff", "tooltip": false },
    "custom/reboot": { "format": "󰜉", "on-click": "systemctl reboot", "tooltip": false },
    "custom/sleep": { "format": "󰒲", "on-click": "systemctl suspend", "tooltip": false },
    "custom/logout": { "format": "󰍃", "on-click": "niri msg action quit", "tooltip": false },

    "privacy": {
        "icon-size": 14,
        "modules": [{ "type": "screenshare", "prefix": "󰒔" }]
    }
}

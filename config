{
    "layer": "top",
    "position": "top",
    "margin-top": 8,
    "height": 40,
    "spacing": 6,

    "modules-center": [
        "group/taskbar_drawer", // Слева: Выезжающий ящик с программами
        "group/hardware",       // Слева: Данные железа
        "clock",                // По центру: Время, день, число, месяц, год
        "custom/settings",      // Справа: Единая кнопка настроек
        "group/power"           // Справа: Кнопка выключения с выезжающим меню
    ],

    // --- ЛЕВАЯ ЧАСТЬ ---
    "group/taskbar_drawer": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": true // Выдвигается вправо от иконки
        },
        "modules": [
            "custom/apps_icon", // То, что видно всегда (триггер)
            "wlr/taskbar"       // Скрыто (Сами программы)
        ]
    },
    "custom/apps_icon": {
        "format": "󰣆", // Иконка-триггер (можно поменять на любую из Nerd Fonts)
        "tooltip-format": "Открытые программы"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": ["waybar"],
        "tooltip-format": "{title}"
    },
    "group/hardware": {
        "orientation": "horizontal",
        "modules": ["cpu", "memory", "temperature", "battery"]
    },
    "cpu": { "format": " {usage}%", "tooltip": false },
    "memory": { "format": " {}%", "tooltip": false },
    "temperature": { "format": " {temperatureC}°C", "tooltip": false },
    "battery": {
        "format": "{icon} {capacity}%",
        "format-charging": "󰂄 {capacity}%",
        "format-plugged": " {capacity}%",
        "format-icons": ["", "", "", "", ""]
    },

    // --- ЦЕНТР ---
    "clock": {
        // Добавлено время (%H:%M) перед датой
        "format": "{:%H:%M • %A, %d %B %Y}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "locale": "ru_RU.UTF-8" 
    },

    // --- ПРАВАЯ ЧАСТЬ ---
    "custom/settings": {
        "format": "",
        "on-click": "swaync-client -t -sw",
        "tooltip": false
    },

    // --- КНОПКА ПИТАНИЯ ---
    "group/power": {
        "orientation": "horizontal",
        "drawer": {
            "transition-duration": 300,
            "transition-left-to-right": false 
        },
        "modules": [
            "custom/power",   
            "custom/reboot",  
            "custom/sleep",   
            "custom/logout"   
        ]
    },
    "custom/power": {
        "format": "",
        "on-click": "systemctl poweroff",
        "tooltip-format": "Выключить ПК"
    },
    "custom/reboot": {
        "format": "󰜉",
        "on-click": "systemctl reboot",
        "tooltip-format": "Перезагрузить"
    },
    "custom/sleep": {
        "format": "󰒲",
        "on-click": "systemctl suspend",
        "tooltip-format": "Спящий режим"
    },
    "custom/logout": {
        "format": "󰍃",
        "on-click": "niri msg action quit", 
        "tooltip-format": "Выйти из системы"
    }
}
